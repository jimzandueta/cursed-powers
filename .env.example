# ─── AI Provider (at least one required) ───────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── API Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=file:./data/wishes.db
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_MAX=50
RATE_LIMIT_WINDOW_MS=14400000

# ─── Security (optional in dev) ────────────────────────────────
TURNSTILE_SECRET_KEY=
REQUEST_SIGNING_KEY=

# ─── Frontend (NEXT_PUBLIC_ vars are exposed to the browser) ──
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_REQUEST_SIGNING_KEY=
