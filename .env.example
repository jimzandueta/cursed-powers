# ─── AI Provider (at least one required) ───────────────────────
# Google Gemini API key — used by the primary AI provider.
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# OpenAI API key — used as the fallback AI provider when Gemini fails.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Web Server ────────────────────────────────────────────────
# Port for the Next.js web frontend.
# On Replit / hosted platforms, set this to the platform-assigned port.
PORT=3000

# ─── API Server ────────────────────────────────────────────────
# Port for the Fastify API backend. Defaults to PORT if not set.
# Set this explicitly on Replit so web (PORT) and API (API_PORT) don't collide.
API_PORT=3001
# Runtime mode — affects logging format, security header strictness, etc.
# Values: development | production | test
NODE_ENV=development
# API log verbosity. Use 'info' in production, 'debug' in development.
# Values: debug | info | warn | error
LOG_LEVEL=debug
# SQLite database file path (relative to the API working directory).
DATABASE_URL=file:./data/wishes.db
# Allowed browser origin for CORS. Must match the deployed frontend URL.
# Comma-separate multiple origins: https://example.com,https://www.example.com
CORS_ORIGIN=http://localhost:3000
# Trust the X-Forwarded-For / X-Real-IP headers from the reverse proxy.
# Set to 'true' on Replit, Railway, Fly.io, or any platform behind a load balancer.
# Leave 'false' for local development.
TRUST_PROXY=false

# ─── Rate Limiting ─────────────────────────────────────────────
# Maximum number of requests a single IP can make within the window.
RATE_LIMIT_MAX=50
# Rate limit window in milliseconds. Default is 4 hours (14400000 ms).
RATE_LIMIT_WINDOW_MS=14400000

# ─── Security ──────────────────────────────────────────────────
# Cloudflare Turnstile secret key — used by the API to validate CAPTCHA tokens.
# Leave empty to disable CAPTCHA checks (fine for local development).
# Get yours at: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=
# HMAC signing secret shared between the frontend and backend.
# The API will reject any request whose signature does not match.
# Leave empty in development to skip signature checks.
# Generate a strong secret with: openssl rand -hex 32
REQUEST_SIGNING_KEY=

# ─── Frontend ──────────────────────────────────────────────────
# NOTE: NEXT_PUBLIC_ variables are compiled into the browser bundle.
# Never put private keys or secrets in NEXT_PUBLIC_ variables.

# Public API base URL used during server-side rendering (when window is undefined).
# Leave empty when using same-origin /api rewrites (Replit single-domain setup).
# Set to full API URL only when running frontend and backend on separate domains.
NEXT_PUBLIC_API_URL=
# Internal API URL used by Next.js server-side rewrites to proxy /api/v1/* requests.
# Must point to where the API process is actually listening (not a public URL).
# For Replit: change to http://127.0.0.1:{API_PORT}
API_INTERNAL_URL=http://127.0.0.1:3001
# Cloudflare Turnstile site key — rendered in the browser CAPTCHA widget.
# Must match the site key paired with TURNSTILE_SECRET_KEY above.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Frontend copy of the HMAC signing key.
# Must be identical to REQUEST_SIGNING_KEY so signatures match.
# Generate with: openssl rand -hex 32
NEXT_PUBLIC_REQUEST_SIGNING_KEY=
